# Blofin API Credentials
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub

# Live Account
BLOFIN_API_KEY=your_live_api_key_here
BLOFIN_API_SECRET=your_live_api_secret_here
BLOFIN_API_PASSPHRASE=your_live_passphrase_here

# Demo Account (for testing)
BLOFIN_DEMO_API_KEY=your_demo_api_key_here
BLOFIN_DEMO_API_SECRET=your_demo_api_secret_here
BLOFIN_DEMO_API_PASSPHRASE=your_demo_passphrase_here

# Bot Mode: 'live' or 'demo'
BLOFIN_MODE=demo

# Grid Bot Settings
SYMBOL=BTC-USDT
TOTAL_CAPITAL=800
LEVERAGE=3
GRID_LEVELS=25
GRID_RANGE_PCT=15
STOP_LOSS_PCT=20
